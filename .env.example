# Preferred: Gemini Developer API key (AI Studio). Do NOT commit real values.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override image model (default: gemini-2.5-flash-image)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: vision model for clickable region detection (default: gemini-2.0-flash)
GEMINI_VISION_MODEL=gemini-2.0-flash

# Optional: OpenAI Images (used only if Gemini key is unset)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3

# Server port (default 3001)
PORT=3001
