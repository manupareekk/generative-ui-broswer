# Copy to .env and fill in. Never commit real keys or a populated .env file.
# Image generation (at least one optional for real images; otherwise SVG stubs)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Output pixel budget for Gemini image gen: 1K | 2K | 4K (default 2K — sharper than 1K when supported)
# GEMINI_IMAGE_SIZE=2K
# Compiler JSON temperature (0.05–0.85; default 0.22 = stabler scene briefs)
# GEMINI_COMPILER_TEMPERATURE=0.22
# Set to 0 to skip post-sharpen on PNG outputs from Gemini
# GEMINI_IMAGE_SHARPEN=1
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GEMINI_COMPILER_MODEL=gemini-2.0-flash
# OPENAI_IMAGE_MODEL=dall-e-3

# Optional: Brave Search API for better retrieval snippets (otherwise DuckDuckGo instant answer)
# BRAVE_SEARCH_API_KEY=
# RETRIEVAL_TOP_N=8

# API port (client dev proxy targets 3020)
CIRCLE_BROWSER_PORT=3020
