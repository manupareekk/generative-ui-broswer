# Copy to .env and fill in. Never commit real keys or a populated .env file.
# Image generation (at least one optional for real images; otherwise SVG stubs)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional model overrides
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GEMINI_COMPILER_MODEL=gemini-2.0-flash
# OPENAI_IMAGE_MODEL=dall-e-3

# Optional: Brave Search API for better retrieval snippets (otherwise DuckDuckGo instant answer)
# BRAVE_SEARCH_API_KEY=
# RETRIEVAL_TOP_N=8

# API port (client dev proxy targets 3020)
CIRCLE_BROWSER_PORT=3020
